@model Contract
@{
    ViewData["Title"] = "Add Contract";
}

<div class="form-page">
    <div class="form-card">
        <div class="form-card-header">
            <i class="fa fa-plus-circle"></i> Add New Contract
        </div>
        <div class="form-card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="auth-error mb-3"></div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="TenantId" class="form-label"></label>
                        <select asp-for="TenantId"
                                asp-items="@(ViewBag.Tenants as SelectList)"
                                class="form-select cp-input">
                            <option value="">-- Select Tenant --</option>
                        </select>
                        <span asp-validation-for="TenantId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="RoomId" class="form-label"></label>
                        <select asp-for="RoomId"
                                asp-items="@(ViewBag.Rooms as SelectList)"
                                class="form-select cp-input">
                            <option value="">-- Select Room --</option>
                        </select>
                        <span asp-validation-for="RoomId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="StartDate" class="form-label"></label>
                        <input asp-for="StartDate" type="date"
                               class="form-control cp-input" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="EndDate" class="form-label"></label>
                        <input asp-for="EndDate" type="date"
                               class="form-control cp-input" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="MonthlyRent" class="form-label"></label>
                        <input asp-for="MonthlyRent" class="form-control cp-input"
                               placeholder="e.g. 8000" />
                        <span asp-validation-for="MonthlyRent" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12 mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control cp-input"
                                  rows="3" placeholder="Optional notes..."></textarea>
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn-primary-cp">
                        <i class="fa fa-save"></i> Save Contract
                    </button>
                    <a asp-action="Index" class="btn-secondary-cp">
                        <i class="fa fa-arrow-left"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>