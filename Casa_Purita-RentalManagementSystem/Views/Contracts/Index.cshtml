@model IEnumerable<Contract>
@{
    ViewData["Title"] = "Contracts";
}

<div class="page-header">
    <h4><i class="fa fa-file-contract"></i> Contract Management</h4>
    <a asp-action="Create" class="btn-primary-cp">
        <i class="fa fa-plus"></i> Add Contract
    </a>
</div>

<!-- Search & Filter -->
<div class="filter-bar">
    <form method="get" class="d-flex gap-2 flex-wrap">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control cp-search"
               placeholder="Search tenant or room..." />
        <select name="status" class="form-select cp-select">
            <option value="">All Status</option>
            <option value="Active" selected="@(ViewBag.Status == "Active")">Active</option>
            <option value="Terminated" selected="@(ViewBag.Status == "Terminated")">Terminated</option>
            <option value="Expired" selected="@(ViewBag.Status == "Expired")">Expired</option>
        </select>
        <button type="submit" class="btn-primary-cp">
            <i class="fa fa-search"></i> Search
        </button>
        <a asp-action="Index" class="btn-secondary-cp">
            <i class="fa fa-rotate"></i> Reset
        </a>
    </form>
</div>

<!-- Contracts Table -->
<div class="table-responsive mt-3">
    @if (Model.Any())
    {
        <table class="cp-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tenant</th>
                    <th>Room</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Monthly Rent</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                }
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@i++</td>
                        <td>@c.Tenant?.FullName</td>
                        <td>Room @c.Room?.RoomNumber</td>
                        <td>@c.StartDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            @c.EndDate.ToString("MMM dd, yyyy")
                            @if (c.IsExpiringSoon)
                            {
                                <span class="badge-warning ms-1">
                                    <i class="fa fa-exclamation-triangle"></i> Soon
                                </span>
                            }
                        </td>
                        <td>₱@c.MonthlyRent.ToString("N0")</td>
                        <td>
                            <span class="status-badge status-@c.Status.ToLower()">
                                @c.Status
                            </span>
                        </td>
                        <td>
                            <div class="action-btns">
                                <a asp-action="Details" asp-route-id="@c.Id"
                                   class="btn-sm-action">
                                    <i class="fa fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@c.Id"
                                   class="btn-sm-edit">
                                    <i class="fa fa-pen"></i>
                                </a>
                                @if (c.Status == "Active")
                                {
                                    <form asp-action="Terminate" asp-route-id="@c.Id"
                                          method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-sm-warning"
                                                onclick="return confirm('Terminate this contract?')">
                                            <i class="fa fa-ban"></i>
                                        </button>
                                    </form>
                                }
                                <a asp-action="Delete" asp-route-id="@c.Id"
                                   class="btn-sm-delete">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <i class="fa fa-file-contract"></i>
            <p>No contracts found.</p>
            <a asp-action="Create" class="btn-primary-cp">Add First Contract</a>
        </div>
    }
</div>