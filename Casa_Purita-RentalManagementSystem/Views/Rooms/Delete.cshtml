@model Room
@{
    ViewData["Title"] = "Delete Room";
}

<div class="form-page">
    <div class="form-card">
        <div class="form-card-header danger">
            <i class="fa fa-trash"></i> Delete Room @Model.RoomNumber
        </div>
        <div class="form-card-body">
            <div class="delete-warning">
                <i class="fa fa-exclamation-triangle"></i>
                Are you sure you want to delete <strong>Room @Model.RoomNumber</strong>?
                This action cannot be undone.
            </div>
            <div class="detail-grid mt-3">
                <div class="detail-item">
                    <span class="detail-label">Room Number</span>
                    <span class="detail-value">@Model.RoomNumber</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Type</span>
                    <span class="detail-value">@Model.Type</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Monthly Rent</span>
                    <span class="detail-value">₱@Model.MonthlyRent.ToString("N0")</span>
                </div>
            </div>
            <form asp-action="Delete" method="post" class="form-actions mt-3">
                <button type="submit" class="btn-danger-cp">
                    <i class="fa fa-trash"></i> Yes, Delete
                </button>
                <a asp-action="Index" class="btn-secondary-cp">
                    <i class="fa fa-arrow-left"></i> Cancel
                </a>
            </form>
        </div>
    </div>
</div>