@model IEnumerable<Room>
@{
    ViewData["Title"] = "Rooms";
}

<div class="page-header">
    <h4><i class="fa fa-door-open"></i> Room Management</h4>
    <a asp-action="Create" class="btn-primary-cp">
        <i class="fa fa-plus"></i> Add Room
    </a>
</div>

<div class="filter-bar">
    <form method="get" class="d-flex gap-2 flex-wrap">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control cp-search"
               placeholder="Search by room number or type..." />
        <select name="filter" class="form-select cp-select">
            <option value="">All Rooms</option>
            <option value="available" selected="@(ViewBag.Filter == "available" ? "selected" : null)">Available</option>
            <option value="occupied" selected="@(ViewBag.Filter == "occupied" ? "selected" : null)">Occupied</option>
        </select>
        <button type="submit" class="btn-primary-cp">
            <i class="fa fa-search"></i> Search
        </button>
        <a asp-action="Index" class="btn-secondary-cp">
            <i class="fa fa-rotate"></i> Reset
        </a>
    </form>
</div>

<div class="table-responsive mt-3">
    @if (Model.Any())
    {
        <table class="cp-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Room Number</th>
                    <th>Type</th>
                    <th>Floor</th>
                    <th>Monthly Rent</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                }
                @foreach (var room in Model)
                {
                    <tr>
                        <td>@i++</td>
                        <td>@room.RoomNumber</td>
                        <td>@room.Type</td>
                        <td>@room.Floor</td>
                        <td>₱@room.MonthlyRent.ToString("N0")</td>
                        <td>
                            <span class="@(room.IsAvailable ? "badge-available" : "badge-occupied")">
                                @(room.IsAvailable ? "Available" : "Occupied")
                            </span>
                        </td>
                        <td>
                            <div class="action-btns">
                                <a asp-action="Details" asp-route-id="@room.Id"
                                   class="btn-sm-action">
                                    <i class="fa fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@room.Id"
                                   class="btn-sm-edit">
                                    <i class="fa fa-pen"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@room.Id"
                                   class="btn-sm-delete">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <i class="fa fa-door-open"></i>
            <p>No rooms found.</p>
            <a asp-action="Create" class="btn-primary-cp">Add First Room</a>
        </div>
    }
</div>