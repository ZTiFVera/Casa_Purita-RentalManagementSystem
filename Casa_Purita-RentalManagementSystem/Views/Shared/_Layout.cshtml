<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Casa Purita – @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet"href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>

    @if (User.Identity!.IsAuthenticated)
    {
        <div class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <i class="fa fa-building"></i>
                <span>Casa Purita</span>
            </div>
            <nav class="sidebar-nav">
                <a asp-controller="Dashboard" asp-action="Index"
                   class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="fa fa-chart-pie"></i><span>Dashboard</span>
                </a>
                <a asp-controller="Rooms" asp-action="Index"
                   class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Rooms" ? "active" : "")">
                    <i class="fa fa-door-open"></i><span>Rooms</span>
                </a>
                <a asp-controller="Tenants" asp-action="Index"
                   class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tenants" ? "active" : "")">
                    <i class="fa fa-users"></i><span>Tenants</span>
                </a>
                <a asp-controller="Contracts" asp-action="Index"
                   class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contracts" ? "active" : "")">
                    <i class="fa fa-file-contract"></i><span>Contracts</span>
                </a>
            </nav>
            <div class="sidebar-footer">
                <span class="user-name">
                    <i class="fa fa-user-circle"></i>
                    @User.Identity.Name
                </span>
                <form asp-controller="Auth" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn">
                        <i class="fa fa-sign-out-alt"></i> Logout
                    </button>
                </form>
            </div>
        </div>

        <div class="main-content" id="mainContent">
            <div class="topbar">
                <button class="toggle-btn" onclick="toggleSidebar()">
                    <i class="fa fa-bars"></i>
                </button>
                <div class="topbar-title">@ViewData["Title"]</div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert-toast success">
                    <i class="fa fa-check-circle"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-toast error">
                    <i class="fa fa-exclamation-circle"></i> @TempData["Error"]
                </div>
            }

            <div class="content-wrapper">
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('collapsed');
            document.getElementById('mainContent').classList.toggle('expanded');
        }

        // Auto-hide toast
        setTimeout(() => {
            const toast = document.querySelector('.alert-toast');
            if (toast) toast.style.display = 'none';
        }, 3500);
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>